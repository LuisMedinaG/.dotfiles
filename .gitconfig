[user]
	name = Luis Medina
	email = luis.hmedinag@gmail.com

[alias]
	undo = reset --soft HEAD^
	st = status
	s  = status --short --branch
	co = checkout
	sw = switch
	br = branch
	ci = commit
	cm = commit -m
	ca = commit --amend --no-edit
	d  = diff
	ds = diff --staged
	lg = log --oneline --graph --decorate --all -20
	last = log -1 HEAD --stat
	hash = rev-parse HEAD
	uncommit = reset --mixed HEAD^
	aliases = config --get-regexp ^alias\\.
[diff]
	colorMoved = zebra
	tool = vscode
[format]
	pretty = oneline
[pull]
	rebase = false
[core]
	editor = code --wait
[rerere]
	enabled = true
[init]
	defaultBranch = main
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[safe]
	directory = /opt/devbox

# Machine-specific git identity. Create ~/.gitconfig-work / ~/.gitconfig-linux
# with [user] email override. These files are NOT tracked by yadm.
[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/Documents/Projects/work/"]
	path = ~/.gitconfig-work
