# ~/.gitignore for yadm — tracks dotfiles in $HOME.
# Add patterns for files that should NOT be committed.

# OS noise
.DS_Store
._*
.Spotlight-V100
.Trashes
.fseventsd
Thumbs.db

# Editor noise
*.swp
*.swo
*.viminfo
.vscode/
.vscode-server/

# Build/dependency artifacts (commonly created in $HOME during dev)
node_modules/
__pycache__/
*.pyc
.tox/

# Caches and logs
.cache/
*.log

# Python venvs
.venv/
venv/
env/

# Tooling state — local/generated files only; settings.json is committed
.claude/settings.local.json
.claude/todos.json

# Machine-local overrides — sourced automatically, never committed.
# These live in $HOME and are intentionally outside yadm tracking.
.zshenv.local
.zprofile.local
.zshrc.local
.aliases.local
.gitconfig-work
.gitconfig-linux
.gitconfig-personal
.config/mackup/backup/

# Secrets — never commit
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
.ssh/
