{
  "effortLevel": "medium",
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "understand-anything@understand-anything": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "extraKnownMarketplaces": {
    "understand-anything": {
      "source": {
        "repo": "Egonex-AI/Understand-Anything",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import json,sys,os; d=json.load(sys.stdin); f=d.get('file_path',''); print(f) if f else None\"); case \"$file\" in *.sh) command -v shellcheck >/dev/null 2>&1 && shellcheck \"$file\" 2>&1 ;; *.zsh) zsh -n \"$file\" 2>&1 ;; esac",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import json,sys,os; d=json.load(sys.stdin); f=d.get('file_path',''); print(os.path.expanduser(f)) if f else None\"); home=$(eval echo ~); case \"$file\" in \"$home/.zsh\"*|\"$home/.zshrc\"*|\"$home/.zshenv\"*|\"$home/.zprofile\"*|\"$home/.zshrc.local\"*|\"$home/.zshenv.local\"*) echo '{\"decision\":\"deny\",\"reason\":\"Edit the dotfiles repo, not $HOME directly. Path: .dotfiles/.zsh/ or root config files.\"}'; exit 2 ;; esac",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "lean-ctx hook rewrite",
            "type": "command"
          }
        ],
        "matcher": "Bash|bash"
      },
      {
        "hooks": [
          {
            "command": "lean-ctx hook redirect",
            "type": "command"
          }
        ],
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "model": "sonnet",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  }
}