#!/usr/bin/env bash
#
# rfv — fuzzy file finder with two modes:
#   rfv           → ripgrep mode (search file contents, toggle to fzf filter)
#   rfv -f [query] [dir]  → fd mode (search file names)
#
# Controls:
#   Ctrl-R  switch to ripgrep mode (content search only)
#   Ctrl-F  switch to fzf filter mode
#   Enter   open selected file in $EDITOR
#
set -euo pipefail

EDITOR="${EDITOR:-vim}"

# ── fd mode: search file names ──
if [[ "${1:-}" == "-f" ]]; then
    shift
    INITIAL_QUERY=""
    DIRECTORY_QUERY=""

    if [[ $# -eq 1 ]]; then
        INITIAL_QUERY="$1"
    elif [[ $# -gt 1 ]]; then
        # All but the last arg = query, last arg = directory
        while [[ $# -gt 1 ]]; do
            INITIAL_QUERY+="$1 "
            shift
        done
        INITIAL_QUERY="${INITIAL_QUERY% }"  # trim trailing space
        DIRECTORY_QUERY="$1"
    fi

    CMD_PREFIX='fd --full-path '
    PREVIEW_CMD='bat --color=always {}'

    IFS=$'\n' read -d '' -ra selected < <(
      FZF_DEFAULT_COMMAND="$CMD_PREFIX $(printf '%q' "$INITIAL_QUERY") $DIRECTORY_QUERY" \
      fzf --multi \
          --ansi \
          --disabled --query "$INITIAL_QUERY" \
          --bind "change:reload:sleep 0.1; $CMD_PREFIX {q} $DIRECTORY_QUERY || true" \
          --preview "$PREVIEW_CMD" \
          --preview-window 'up,60%,border-bottom,~3'
    ) || true

    [[ -n "${selected[*]:-}" ]] && "$EDITOR" "${selected[@]}"
    exit 0
fi

# ── ripgrep mode: search file contents ──
rm -f /tmp/rg-fzf-{r,f}
RG_PREFIX="rg --column --line-number --no-heading --color=always --smart-case "
INITIAL_QUERY="${*:-}"

fzf --ansi --disabled --query "$INITIAL_QUERY" \
    --bind "start:reload($RG_PREFIX {q})+unbind(ctrl-r)" \
    --bind "change:reload:sleep 0.1; $RG_PREFIX {q} || true" \
    --bind "ctrl-f:unbind(change,ctrl-f)+change-prompt(2. fzf> )+enable-search+rebind(ctrl-r)+transform-query(echo {q} > /tmp/rg-fzf-r; cat /tmp/rg-fzf-f)" \
    --bind "ctrl-r:unbind(ctrl-r)+change-prompt(1. ripgrep> )+disable-search+reload($RG_PREFIX {q} || true)+rebind(change,ctrl-f)+transform-query(echo {q} > /tmp/rg-fzf-f; cat /tmp/rg-fzf-r)" \
    --color "hl:-1:underline,hl+:-1:underline:reverse" \
    --prompt '1. ripgrep> ' \
    --delimiter : \
    --header '╱ CTRL-R (ripgrep mode) ╱ CTRL-F (fzf mode) ╱' \
    --preview 'bat --color=always {1} --highlight-line {2}' \
    --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \
    --bind "enter:become($EDITOR {1} +{2})"
