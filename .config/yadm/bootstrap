#!/bin/sh
#
# Bootstrap script for setting up a new macOS machine.
#
# This is the entry point called by `yadm clone --bootstrap`.
# Each phase is an independent script that can also be run standalone.
#
# Phases:
#   00-backup.sh    — Backup existing dotfiles before overwriting
#   01-homebrew.sh  — Install Homebrew + Brewfile packages
#   02-dotfiles.sh  — Checkout dotfiles, init submodules
#   03-shell.sh     — fzf setup, create required directories
#   04-macos.sh     — macOS defaults (OPT-IN, not run by default)
#
# Usage:
#   yadm bootstrap              # runs phases 01–03
#   sh ~/.config/yadm/phases/04-macos.sh   # run macOS defaults manually
#
set -eu

cd "$HOME" || exit 1

# Profile: "personal" (default) or "work" (minimal, no casks)
DOTFILES_PROFILE="${DOTFILES_PROFILE:-personal}"
export DOTFILES_PROFILE
echo "Profile: $DOTFILES_PROFILE"

PHASES_DIR="$HOME/.config/yadm/phases"

if [ ! -d "$PHASES_DIR" ]; then
  echo "Error: phases directory not found at $PHASES_DIR" >&2
  exit 1
fi

# Phase 00: Backup existing files before overwriting
if [ -f "$PHASES_DIR/00-backup.sh" ]; then
  echo ""
  echo "▶ Running 00-backup.sh..."
  echo "────────────────────────────────────────"
  sh "$PHASES_DIR/00-backup.sh"
  echo ""
fi

# Run phases 01–03 (04-macos is opt-in)
for phase in "$PHASES_DIR"/0[1-3]-*.sh; do
  if [ -f "$phase" ]; then
    echo ""
    echo "▶ Running $(basename "$phase")..."
    echo "────────────────────────────────────────"
    sh "$phase"
    echo ""
  fi
done

# Offer to run macOS system defaults (phase 04)
if [ -t 0 ]; then
  printf "Would you like to apply macOS system defaults? [y/N] "
  read -r answer
  if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    echo ""
    echo "▶ Running 04-macos.sh..."
    echo "────────────────────────────────────────"
    sh "$PHASES_DIR/04-macos.sh"
    echo ""
  fi
fi

# Offer to restore app settings via mackup (personal profile only)
if [ -t 0 ] && [ "${DOTFILES_PROFILE}" != "work" ] && command -v mackup >/dev/null 2>&1; then
  MACKUP_BACKUP_DIR="$HOME/.config/mackup/backup"
  if [ -d "$MACKUP_BACKUP_DIR" ] && [ -n "$(ls -A "$MACKUP_BACKUP_DIR" 2>/dev/null)" ]; then
    printf "Would you like to restore app settings via mackup? [y/N] "
    read -r answer
    if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
      echo ""
      echo "▶ Restoring app settings with mackup..."
      echo "────────────────────────────────────────"
      mackup restore --force
      echo "✓ mackup restore complete."
      echo ""
    fi
  fi
fi

echo "════════════════════════════════════════"
echo "✓ Bootstrap complete!"
echo "════════════════════════════════════════"
echo ""
if [ ! -t 0 ]; then
  echo "Optional: run macOS system defaults with:"
  echo "  sh ~/.config/yadm/phases/04-macos.sh"
  echo ""
fi
LATEST_BACKUP="$(ls -dt "$HOME/.config/yadm/backup"/*/ 2>/dev/null | head -1)"
if [ -n "$LATEST_BACKUP" ]; then
  echo "── Backup ──"
  echo ""
  echo "  Your previous config files were saved to:"
  echo "  $LATEST_BACKUP"
  echo ""
  echo "  Review and merge what you need into .local files:"
  echo "    ~/.zshenv.local   (env vars, PATH — all shells)"
  echo "    ~/.zprofile.local (login-shell setup)"
  echo "    ~/.zshrc.local    (aliases, functions, interactive)"
  echo ""
  echo "  Quick diff example:"
  echo "    diff ~/.zshrc ${LATEST_BACKUP}.zshrc"
  echo ""
fi
echo "Open a new terminal to pick up all changes."
echo ""
echo "── Manual steps (macOS permissions) ──"
echo ""
echo "  System Settings > Privacy & Security > Input Monitoring:"
echo "    [ ] Karabiner-Elements"
echo "    [ ] Karabiner-EventViewer"
kanata_bin="$(command -v kanata 2>/dev/null || echo '/usr/local/bin/kanata')"
if [ "$DOTFILES_PROFILE" = "personal" ]; then
  echo "    [ ] kanata ($kanata_bin)"
  echo ""
  echo "  System Settings > Privacy & Security > Full Disk Access:"
  echo "    [ ] kanata ($kanata_bin)"
  echo ""
  echo "  System Settings > Privacy & Security > Accessibility:"
  echo "    [ ] Karabiner-Elements"
  echo "    [ ] Homerow"
  echo "    [ ] BetterTouchTool"
  echo "    [ ] Raycast"
  echo ""
  echo "  Post-setup:"
  echo "    [ ] sh ~/.config/yadm/phases/04-macos.sh  (macOS defaults)"
  echo "    [ ] kanata-reload                         (start kanata daemon)"
  echo "    [ ] karabiner-build                       (generate karabiner.json)"
fi
echo ""
