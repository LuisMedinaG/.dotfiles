#!/bin/sh
#
# Bootstrap script for setting up a new macOS machine.
#
# This is the entry point called by `yadm clone --bootstrap`.
# Each phase is an independent script that can also be run standalone.
#
# Phases:
#   01-homebrew.sh  — Install Homebrew + Brewfile packages
#   02-dotfiles.sh  — Checkout dotfiles, init submodules
#   03-shell.sh     — fzf setup, create required directories
#   04-macos.sh     — macOS defaults (OPT-IN, not run by default)
#
# Usage:
#   yadm bootstrap              # runs phases 01–03
#   sh ~/.config/yadm/phases/04-macos.sh   # run macOS defaults manually
#
set -eu

cd "$HOME" || exit 1

# Profile: "personal" (default) or "work" (minimal, no casks)
DOTFILES_PROFILE="${DOTFILES_PROFILE:-personal}"
export DOTFILES_PROFILE
echo "Profile: $DOTFILES_PROFILE"

PHASES_DIR="$HOME/.config/yadm/phases"

if [ ! -d "$PHASES_DIR" ]; then
  echo "Error: phases directory not found at $PHASES_DIR" >&2
  exit 1
fi

# Run phases 01–03 (04-macos is opt-in)
for phase in "$PHASES_DIR"/0[1-3]-*.sh; do
  if [ -f "$phase" ]; then
    echo ""
    echo "▶ Running $(basename "$phase")..."
    echo "────────────────────────────────────────"
    sh "$phase"
    echo ""
  fi
done

# Offer to run macOS system defaults (phase 04)
if [ -t 0 ]; then
  printf "Would you like to apply macOS system defaults? [y/N] "
  read -r answer
  if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    echo ""
    echo "▶ Running 04-macos.sh..."
    echo "────────────────────────────────────────"
    sh "$PHASES_DIR/04-macos.sh"
    echo ""
  fi
fi

echo "════════════════════════════════════════"
echo "✓ Bootstrap complete!"
echo ""
if [ ! -t 0 ]; then
  echo "Optional: run macOS system defaults with:"
  echo "  sh ~/.config/yadm/phases/04-macos.sh"
  echo ""
fi
echo "Open a new terminal to pick up all changes."
echo "════════════════════════════════════════"
