#!/bin/sh
#
# Bootstrap script for setting up a new macOS machine.
#
# This is the entry point called by `yadm clone --bootstrap`.
# Each phase is an independent script that can also be run standalone.
#
# Phases:
#   00-backup.sh    вЂ” Backup existing dotfiles before overwriting
#   01-homebrew.sh  вЂ” Install Homebrew + Brewfile packages
#   02-dotfiles.sh  вЂ” Checkout dotfiles, init submodules
#   03-shell.sh     вЂ” fzf setup, create required directories
#   04-macos.sh     вЂ” macOS defaults (OPT-IN, not run by default)
#
# Usage:
#   yadm bootstrap              # runs phases 01вЂ“03
#   sh ~/.config/yadm/phases/04-macos.sh   # run macOS defaults manually
#
set -eu

cd "$HOME" || exit 1

# Profile: "personal" (full setup) or "work" (CLI only, no casks)
if [ -z "${DOTFILES_PROFILE:-}" ] && [ -t 0 ]; then
  echo ""
  echo "Select profile:"
  echo "  1) personal  вЂ” Full setup: CLI + GUI apps + mackup"
  echo "  2) work      вЂ” Minimal: CLI tools only, no casks"
  echo "  3) linuxbox  вЂ” Linux dev box: CLI tools, no macOS-specific software"
  echo ""
  printf "Profile [1/2/3]: "
  read -r profile_choice
  case "$profile_choice" in
    2|work)     DOTFILES_PROFILE="work" ;;
    3|linuxbox) DOTFILES_PROFILE="linuxbox" ;;
    *)          DOTFILES_PROFILE="personal" ;;
  esac
else
  DOTFILES_PROFILE="${DOTFILES_PROFILE:-personal}"
fi
export DOTFILES_PROFILE
echo "Profile: $DOTFILES_PROFILE"

LOG_DIR="$HOME/.config/yadm/logs"
LOG_FILE="$LOG_DIR/bootstrap-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "$LOG_DIR"
echo "Logging to: $LOG_FILE"
echo "bootstrap started: $(date)" >> "$LOG_FILE"
echo "profile: $DOTFILES_PROFILE"  >> "$LOG_FILE"

PHASES_DIR="$HOME/.config/yadm/phases"

if [ ! -d "$PHASES_DIR" ]; then
  echo "Error: phases directory not found at $PHASES_DIR" >&2
  exit 1
fi

run_phase() {
  _phase="$1"
  _name="$(basename "$_phase")"
  echo ""
  echo "в–¶ Running $_name..."
  echo "в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
  printf '\nв–¶ %s\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n' "$_name" >> "$LOG_FILE"
  sh "$_phase" 2>&1 | tee -a "$LOG_FILE"
  echo ""
}

# Phase 00: Backup existing files before overwriting
if [ -f "$PHASES_DIR/00-backup.sh" ]; then
  run_phase "$PHASES_DIR/00-backup.sh"
fi

# Run phases 01вЂ“03 (04-macos is opt-in)
for phase in "$PHASES_DIR"/0[1-3]-*.sh; do
  [ -f "$phase" ] && run_phase "$phase"
done

# Run linuxbox phase (Linux-specific tooling, opt-in via profile)
if [ "${DOTFILES_PROFILE}" = "linuxbox" ] && [ -f "$PHASES_DIR/05-linuxbox.sh" ]; then
  run_phase "$PHASES_DIR/05-linuxbox.sh"
fi

# Offer to run macOS system defaults (phase 04)
if [ -t 0 ] && [ "$(uname -s)" = "Darwin" ]; then
  printf "Would you like to apply macOS system defaults? [y/N] "
  read -r answer
  if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    run_phase "$PHASES_DIR/04-macos.sh"
  fi
fi

# Offer to restore app settings via mackup (personal profile only)
if [ -t 0 ] && [ "${DOTFILES_PROFILE}" = "personal" ] && command -v mackup >/dev/null 2>&1; then
  MACKUP_BACKUP_DIR="$HOME/.config/mackup/backup"
  if [ -d "$MACKUP_BACKUP_DIR" ] && [ -n "$(ls -A "$MACKUP_BACKUP_DIR" 2>/dev/null)" ]; then
    printf "Would you like to restore app settings via mackup? [y/N] "
    read -r answer
    if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
      echo ""
      echo "в–¶ Restoring app settings with mackup..."
      echo "в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
      printf '\nв–¶ mackup restore\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n' >> "$LOG_FILE"
      mackup restore --force 2>&1 | tee -a "$LOG_FILE"
      echo "вњ“ mackup restore complete."
      echo ""
    fi
  fi
fi

echo "в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
echo "вњ“ Bootstrap complete!"
echo "в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ"
echo "bootstrap finished: $(date)" >> "$LOG_FILE"
echo "Log saved to: $LOG_FILE"
echo ""
if [ ! -t 0 ]; then
  echo "Optional: run macOS system defaults with:"
  echo "  sh ~/.config/yadm/phases/04-macos.sh"
  echo ""
fi
LATEST_BACKUP="$(ls -dt "$HOME/.config/yadm/backup"/*/ 2>/dev/null | head -1)"
if [ -n "$LATEST_BACKUP" ]; then
  echo "в”Ђв”Ђ Backup в”Ђв”Ђ"
  echo ""
  echo "  Your previous config files were saved to:"
  echo "  $LATEST_BACKUP"
  echo ""
  echo "  Review and merge what you need into .local files:"
  echo "    ~/.zshenv.local   (env vars, PATH вЂ” all shells)"
  echo "    ~/.zprofile.local (login-shell setup)"
  echo "    ~/.zshrc.local    (aliases, functions, interactive)"
  echo ""
  echo "  Quick diff example:"
  echo "    diff ~/.zshrc ${LATEST_BACKUP}.zshrc"
  echo ""
fi
echo "Open a new terminal to pick up all changes."
echo ""
if [ "$(uname -s)" = "Darwin" ]; then
echo "в”Ђв”Ђ Manual steps (macOS permissions) в”Ђв”Ђ"
echo ""
echo "  System Settings > Privacy & Security > Input Monitoring:"
echo "    [ ] Karabiner-Elements"
echo "    [ ] Karabiner-EventViewer"
kanata_bin="$(command -v kanata 2>/dev/null || echo '/usr/local/bin/kanata')"
if [ "$DOTFILES_PROFILE" = "personal" ]; then
  echo "    [ ] kanata ($kanata_bin)"
  echo ""
  echo "  System Settings > Privacy & Security > Full Disk Access:"
  echo "    [ ] kanata ($kanata_bin)"
  echo ""
  echo "  System Settings > Privacy & Security > Accessibility:"
  echo "    [ ] Karabiner-Elements"
  echo "    [ ] Homerow"
  echo "    [ ] BetterTouchTool"
  echo "    [ ] Raycast"
  echo ""
  echo "  Post-setup:"
  echo "    [ ] sh ~/.config/yadm/phases/04-macos.sh  (macOS defaults)"
  echo "    [ ] kanata-reload                         (start kanata daemon)"
  echo "    [ ] karabiner-build                       (generate karabiner.json)"
fi
echo ""
fi  # end Darwin-only manual steps
